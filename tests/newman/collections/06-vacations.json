{
  "info": {
    "_postman_id": "b6c7d8e9-f0a1-4b2c-9d3e-4f5a6b7c8d9e",
    "name": "06 - Vacations",
    "description": "CRUD tests for vacation auto-responder endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const loginRequest = {",
          "    url: pm.environment.get(\"api_base\") + \"/auth/login\",",
          "    method: \"POST\",",
          "    header: {\"Content-Type\": \"application/json\"},",
          "    body: {mode: \"raw\", raw: JSON.stringify({username: pm.environment.get(\"admin_username\"), password: pm.environment.get(\"admin_password\")})}",
          "};",
          "pm.sendRequest(loginRequest, function(err, res) {",
          "    if (!err && res.code === 200) {",
          "        const json = res.json();",
          "        pm.environment.set(\"access_token\", json.access_token);",
          "        pm.environment.set(\"refresh_token\", json.refresh_token);",
          "    }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup: Create test domain",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"domain\":\"newman-test.example.com\",\"description\":\"Newman vacation test domain\",\"aliases\":100,\"mailboxes\":100,\"maxquota\":10240}"
        },
        "url": {
          "raw": "{{api_base}}/domains",
          "host": ["{{api_base}}"],
          "path": ["domains"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Setup: domain created (201) or already exists (409)\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup: Create test mailbox",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"user@newman-test.example.com\",\"password\":\"TestPass123!\",\"name\":\"Newman Test User\",\"quota\":1024,\"active\":true}"
        },
        "url": {
          "raw": "{{api_base}}/mailboxes",
          "host": ["{{api_base}}"],
          "path": ["mailboxes"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Setup: mailbox created (201) or already exists (409)\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Upsert vacation",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"subject\":\"Out of Office\",\"body\":\"I am currently out of the office. I will return on Monday.\",\"active\":true,\"active_from\":\"2099-01-01T00:00:00Z\",\"active_until\":\"2099-01-15T23:59:59Z\"}"
        },
        "url": {
          "raw": "{{api_base}}/mailboxes/user@newman-test.example.com/vacation",
          "host": ["{{api_base}}"],
          "path": ["mailboxes", "user@newman-test.example.com", "vacation"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains vacation data\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"data\");",
              "    pm.expect(json.data).to.have.property(\"email\", \"user@newman-test.example.com\");",
              "    pm.expect(json.data).to.have.property(\"subject\", \"Out of Office\");",
              "    pm.expect(json.data).to.have.property(\"body\");",
              "    pm.expect(json.data).to.have.property(\"active\", true);",
              "    pm.expect(json.data).to.have.property(\"active_from\");",
              "    pm.expect(json.data).to.have.property(\"active_until\");",
              "    pm.expect(json.data).to.have.property(\"domain\", \"newman-test.example.com\");",
              "    pm.expect(json.data).to.have.property(\"interval_time\");",
              "    pm.expect(json.data).to.have.property(\"created_at\");",
              "    pm.expect(json.data).to.have.property(\"updated_at\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get vacation",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/mailboxes/user@newman-test.example.com/vacation",
          "host": ["{{api_base}}"],
          "path": ["mailboxes", "user@newman-test.example.com", "vacation"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Vacation data has subject\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"data\");",
              "    pm.expect(json.data).to.have.property(\"subject\", \"Out of Office\");",
              "    pm.expect(json.data).to.have.property(\"email\", \"user@newman-test.example.com\");",
              "    pm.expect(json.data).to.have.property(\"active\", true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete vacation",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/mailboxes/user@newman-test.example.com/vacation",
          "host": ["{{api_base}}"],
          "path": ["mailboxes", "user@newman-test.example.com", "vacation"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 204\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "pm.test(\"Response body is empty\", function () {",
              "    pm.expect(pm.response.text()).to.be.oneOf([\"\", undefined]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get deleted vacation returns 404",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/mailboxes/user@newman-test.example.com/vacation",
          "host": ["{{api_base}}"],
          "path": ["mailboxes", "user@newman-test.example.com", "vacation"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Response is RFC 7807 problem details\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"type\");",
              "    pm.expect(json).to.have.property(\"title\");",
              "    pm.expect(json).to.have.property(\"status\", 404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Cleanup: Delete test mailbox",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/mailboxes/user@newman-test.example.com",
          "host": ["{{api_base}}"],
          "path": ["mailboxes", "user@newman-test.example.com"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Cleanup: mailbox deleted (204) or not found (404)\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([204, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Cleanup: Delete test domain",
      "request": {
        "method": "DELETE",
        "header": [
          {
