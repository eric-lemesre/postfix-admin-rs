	"item": [
		{
			"name": "GET domain without auth returns 401",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{api_base}}/domains/nonexistent.invalid",
					"host": ["{{api_base}}"],
					"path": ["domains", "nonexistent.invalid"]
				}
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"Status code is 401\", function () {",
							"    pm.response.to.have.status(401);",
							"});",
							"",
							"pm.test(\"Response is RFC 7807 Problem Details\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property(\"type\");",
							"    pm.expect(json).to.have.property(\"title\");",
							"    pm.expect(json).to.have.property(\"status\");",
							"    pm.expect(json).to.have.property(\"detail\");",
							"});",
							"",
							"pm.test(\"Status field matches HTTP status\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.status).to.eql(401);",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "Authenticate for subsequent tests",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"username\":\"{{admin_username}}\",\"password\":\"{{admin_password}}\"}"
				},
				"url": {
					"raw": "{{api_base}}/auth/login",
					"host": ["{{api_base}}"],
					"path": ["auth", "login"]
				}
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has access_token\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property(\"access_token\");",
							"    pm.environment.set(\"access_token\", json.access_token);",
							"});",
							"",
							"pm.test(\"Response has refresh_token\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property(\"refresh_token\");",
							"    pm.environment.set(\"refresh_token\", json.refresh_token);",
							"});"
						]
					}
				}
			]
		},
