          }
        ],
        "url": {
          "raw": "{{api_base}}/domains/newman-test.example.com",
          "host": ["{{api_base}}"],
          "path": ["domains", "newman-test.example.com"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Cleanup: domain deleted (204) or not found (404)\", function () {",
