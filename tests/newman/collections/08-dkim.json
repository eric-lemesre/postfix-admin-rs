              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete DKIM signing",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/dkim/signings/{{dkim_signing_id}}",
