					"raw": "{{api_base}}/alias-domains/newman-alias.example.com",
					"host": ["{{api_base}}"],
					"path": ["alias-domains", "newman-alias.example.com"]
				}
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"Status code is 204\", function () {",
							"    pm.response.to.have.status(204);",
							"});",
							"",
							"pm.test(\"Response body is empty\", function () {",
							"    pm.expect(pm.response.text()).to.be.oneOf([\"\", undefined]);",
							"});"
						]
					}
				}
			]
		},
