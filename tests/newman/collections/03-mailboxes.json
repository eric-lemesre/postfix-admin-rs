      }
    },
    {
      "name": "Cleanup - Delete test domain",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 204 or 404', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([204, 404]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
