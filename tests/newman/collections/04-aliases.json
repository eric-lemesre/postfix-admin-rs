{
  "info": {
    "_postman_id": "d4e5f6a7-b8c9-0123-defa-234567890104",
    "name": "04 - Aliases",
    "description": "Alias CRUD endpoints for the postfix-admin-rs REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Authenticate and create test domain before running alias tests",
          "var apiBase = pm.environment.get('api_base');",
          "",
          "// Step 1: Login to get access token",
          "var loginRequest = {",
          "    url: apiBase + '/auth/login',",
          "    method: 'POST',",
          "    header: {",
          "        'Content-Type': 'application/json'",
          "    },",
          "    body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({",
          "            username: pm.environment.get('admin_username'),",
          "            password: pm.environment.get('admin_password')",
          "        })",
          "    }",
          "};",
          "",
          "pm.sendRequest(loginRequest, function (err, res) {",
          "    if (err) {",
          "        console.error('Login failed:', err);",
          "        return;",
          "    }",
          "    var jsonData = res.json();",
          "    pm.environment.set('access_token', jsonData.access_token);",
          "    pm.environment.set('refresh_token', jsonData.refresh_token);",
          "",
          "    // Step 2: Create the test domain (ignore 409 if it already exists)",
          "    var createDomainRequest = {",
          "        url: apiBase + '/domains',",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/json',",
          "            'Authorization': 'Bearer ' + jsonData.access_token",
          "        },",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                domain: 'newman-test.example.com',",
          "                description: 'Newman alias test domain',",
          "                aliases: 100,",
          "                mailboxes: 50,",
          "                maxquota: 10240,",
          "                quota: 51200,",
          "                active: true",
          "            })",
          "        }",
          "    };",
          "",
          "    pm.sendRequest(createDomainRequest, function (err, res) {",
          "        if (err) {",
          "            console.error('Create domain failed:', err);",
          "        }",
          "        // 201 = created, 409 = already exists (both are acceptable)",
          "    });",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Create alias",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response body has data object', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('object');",
              "});",
              "",
              "pm.test('Alias address matches', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.address).to.eql('alias@newman-test.example.com');",
              "});",
              "",
              "pm.test('Alias goto matches', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.goto).to.eql('dest@other.com');",
              "});",
              "",
              "pm.test('Alias has expected fields', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('address');",
              "    pm.expect(jsonData.data).to.have.property('goto');",
              "    pm.expect(jsonData.data).to.have.property('domain');",
              "    pm.expect(jsonData.data).to.have.property('active');",
              "    pm.expect(jsonData.data).to.have.property('created_at');",
              "    pm.expect(jsonData.data).to.have.property('updated_at');",
              "});",
              "",
              "pm.test('Alias domain matches', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.domain).to.eql('newman-test.example.com');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"address\":\"alias@newman-test.example.com\",\"goto\":\"dest@other.com\",\"active\":true}"
        },
        "url": {
          "raw": "{{api_base}}/aliases",
          "host": ["{{api_base}}"],
          "path": ["aliases"]
        }
      }
    },
    {
      "name": "List aliases for domain",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response body has data array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "",
              "pm.test('Data array has at least one alias', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.length).to.be.at.least(1);",
              "});",
              "",
              "pm.test('Response body has meta object', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('meta');",
              "    pm.expect(jsonData.meta).to.have.property('total');",
              "    pm.expect(jsonData.meta).to.have.property('page');",
              "    pm.expect(jsonData.meta).to.have.property('per_page');",
              "    pm.expect(jsonData.meta).to.have.property('total_pages');",
              "});",
              "",
              "pm.test('At least one alias belongs to test domain', function () {",
              "    var jsonData = pm.response.json();",
              "    var found = jsonData.data.some(function (a) {",
              "        return a.domain === 'newman-test.example.com';",
              "    });",
              "    pm.expect(found).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/domains/newman-test.example.com/aliases",
          "host": ["{{api_base}}"],
          "path": ["domains", "newman-test.example.com", "aliases"]
        }
      }
    },
    {
      "name": "Get alias",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response body has data object', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('object');",
              "});",
              "",
              "pm.test('Alias address matches', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.address).to.eql('alias@newman-test.example.com');",
              "});",
              "",
              "pm.test('Alias goto matches', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.goto).to.eql('dest@other.com');",
              "});",
              "",
              "pm.test('Alias is active', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.active).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base}}/aliases/alias@newman-test.example.com",
          "host": ["{{api_base}}"],
          "path": ["aliases", "alias@newman-test.example.com"]
        }
      }
    },
    {
      "name": "Update alias goto",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response body has data object', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('object');",
              "});",
              "",
              "pm.test('Alias goto was updated', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.goto).to.eql('newdest@other.com');",
              "});",
              "",
              "pm.test('Alias address is unchanged', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.address).to.eql('alias@newman-test.example.com');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"goto\":\"newdest@other.com\"}"
        },
        "url": {
          "raw": "{{api_base}}/aliases/alias@newman-test.example.com",
          "host": ["{{api_base}}"],
          "path": ["aliases", "alias@newman-test.example.com"]
        }
      }
    },
    {
